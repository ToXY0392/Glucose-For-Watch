    <string name="wear_install_direct_install_btn">Installer l’app sur la montre</string>
    <string name="wear_install_direct_pair_ok">Lien réussi. Sur la montre, notez le deuxième port (adresse IP et port). Recopiez‑le ci‑dessous, puis touchez Installer.</string>
    <string name="wear_install_direct_install_ok">Envoi terminé. Regardez la montre, puis lisez la suite sur cet écran.</string>
    <string name="wear_install_direct_err_generic">Échec : %1$s</string>
    <string name="wear_install_direct_err_fill">Il manque des numéros. Vérifiez les trois champs du haut, puis le port d’installation.</string>
    <string name="wear_install_direct_err_pair_fields">Remplissez le premier port et le code à six chiffres comme sur la montre.</string>
    <string name="wear_install_after">Quand c’est fini, vous pourrez désactiver « Débogage Wi‑Fi » sur la montre pour plus de calme. Glucose For Watch n’est pas un remplacement de l’application Dexcom officielle.</string>
