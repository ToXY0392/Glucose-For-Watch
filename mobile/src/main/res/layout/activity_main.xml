<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_mobile_backdrop">

    <ScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="start"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingTop="56dp"
            android:paddingEnd="28dp"
            android:paddingBottom="36dp">

            <ImageView
                android:id="@+id/appLogoImage"
                android:layout_width="170dp"
                android:layout_height="118dp"
                android:adjustViewBounds="true"
                android:contentDescription="Widget G7"
                android:scaleType="fitStart"
                android:src="@drawable/logo_widget_g7_official" />

            <TextView
                android:id="@+id/homeStatusPill"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_home_status_pill"
                android:ellipsize="end"
                android:maxLines="2"
                android:paddingStart="16dp"
                android:paddingTop="12dp"
                android:paddingEnd="16dp"
                android:paddingBottom="12dp"
                android:textColor="@color/wg7_accent_dark"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/installCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_step_card_modern"
                    android:elevation="2dp"
                    android:minHeight="104dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="20dp"
                        android:paddingTop="16dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="16dp">

                        <ImageView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_watch_install" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="18dp"
                            android:layout_weight="1"
                            android:text="Installer Wear"
                            android:textColor="@color/wg7_text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/installChevron"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:contentDescription="@null"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_chevron_forward_24"
                            android:tint="@color/wg7_text_secondary" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/syncCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_step_card_modern"
                    android:elevation="2dp"
                    android:minHeight="104dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="20dp"
                        android:paddingTop="16dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="16dp">

                        <ImageView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_refresh_24"
                            android:tint="@color/wg7_accent_dark" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="18dp"
                            android:layout_weight="1"
                            android:text="Synchroniser"
                            android:textColor="@color/wg7_text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/syncChevron"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:contentDescription="@null"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_chevron_forward_24"
                            android:tint="@color/wg7_text_secondary" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ackCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_step_card_modern"
                    android:elevation="2dp"
                    android:minHeight="104dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="20dp"
                        android:paddingTop="16dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="16dp">

                        <ImageView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_watch_ack" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="18dp"
                            android:layout_weight="1"
                            android:text="Confirmer la montre"
                            android:textColor="@color/wg7_text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/ackChevron"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:contentDescription="@null"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_chevron_forward_24"
                            android:tint="@color/wg7_text_secondary" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <ImageButton
        android:id="@+id/watchSettingsButton"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="18dp"
        android:alpha="0.01"
        android:background="@android:color/transparent"
        android:contentDescription="Parametres"
        android:padding="10dp"
        android:src="@drawable/ic_settings_24" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/watchRefreshButton"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:alpha="0"
        android:enabled="true"
        android:text="Synchroniser" />

    <TextView
        android:id="@+id/openNoticeButton"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:alpha="0"
        android:text="Notice" />

    <LinearLayout
        android:id="@+id/watchActionRow"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:alpha="0"
        android:orientation="horizontal" />
</FrameLayout>
