<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_premium_canvas">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:scrollbars="none">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="40dp">

            <ImageButton
                android:id="@+id/watchSettingsButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_icon_square_ripple"
                android:contentDescription="@string/menu_content_description"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_settings_24"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/wg7_text_primary" />

            <FrameLayout
                android:id="@+id/brandMarkFrame"
                android:layout_width="@dimen/wg7_icon_tonal_size"
                android:layout_height="@dimen/wg7_icon_tonal_size"
                android:layout_marginStart="@dimen/wg7_screen_pad_h"
                android:layout_marginTop="26dp"
                android:background="@drawable/bg_brand_mark_frame"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/brandMarkImage"
                    android:layout_width="@dimen/wg7_icon_square_inner"
                    android:layout_height="@dimen/wg7_icon_square_inner"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_brand_mark" />
            </FrameLayout>

            <LinearLayout
                android:id="@+id/brandTextColumn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="@dimen/wg7_screen_pad_h"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="@id/brandMarkFrame"
                app:layout_constraintEnd_toStartOf="@id/watchSettingsButton"
                app:layout_constraintStart_toEndOf="@id/brandMarkFrame"
                app:layout_constraintTop_toTopOf="@id/brandMarkFrame">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:includeFontPadding="false"
                    android:letterSpacing="-0.045"
                    android:text="@string/app_name"
                    android:textColor="@color/wg7_text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:includeFontPadding="false"
                    android:letterSpacing="0.04"
                    android:text="@string/home_brand_tagline"
                    android:textColor="@color/wg7_text_tertiary"
                    android:textSize="11sp" />
            </LinearLayout>

            <androidx.constraintlayout.widget.Barrier
                android:id="@+id/headerBarrier"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="bottom"
                app:constraint_referenced_ids="brandMarkFrame,brandTextColumn" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/heroCard"
                style="@style/Widget.WidgetG7.SectionCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/wg7_screen_pad_h"
                android:layout_marginTop="22dp"
                android:layout_marginEnd="@dimen/wg7_screen_pad_h"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/headerBarrier">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="24dp"
                    android:paddingTop="24dp"
                    android:paddingEnd="22dp"
                    android:paddingBottom="22dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/homeReadingPrimary"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="sans-serif-black"
                            android:gravity="center_vertical"
                            android:letterSpacing="-0.05"
                            android:lineSpacingExtra="0dp"
                            android:textColor="@color/wg7_text_primary"
                            android:textSize="56sp"
                            android:textStyle="bold" />

                        <ImageButton
                            android:id="@+id/syncNowButton"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/bg_sync_button_tonal"
                            android:contentDescription="@string/home_sync_content_description"
                            android:padding="13dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_refresh_24"
                            app:tint="@color/wg7_text_primary" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/homeReadingSubtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:letterSpacing="-0.01"
                        android:lineSpacingMultiplier="1.25"
                        android:textColor="@color/wg7_text_secondary"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/homeStatusText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:background="@drawable/bg_status_pill_neutral"
                        android:letterSpacing="-0.01"
                        android:lineSpacingMultiplier="1.15"
                        android:paddingStart="12dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="8dp"
                        android:textColor="@color/wg7_text_secondary"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/homeSectionDataLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/wg7_screen_pad_h"
                android:layout_marginTop="28dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="-0.01"
                android:text="@string/home_section_data"
                android:textColor="@color/wg7_text_tertiary"
                android:textSize="13sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/heroCard" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/dexcomCard"
                style="@style/Widget.WidgetG7.SectionCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/wg7_screen_pad_h"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="@dimen/wg7_screen_pad_h"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/homeSectionDataLabel">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:gravity="center_vertical"
                    android:minHeight="88dp"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingTop="18dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="18dp">

                    <FrameLayout
                        android:id="@+id/dexcomStatusButton"
                        android:layout_width="@dimen/wg7_icon_tonal_size"
                        android:layout_height="@dimen/wg7_icon_tonal_size"
                        android:background="@drawable/bg_dexcom_status_disconnected"
                        android:contentDescription="@string/home_dexcom_status_disconnected_desc"
                        android:importantForAccessibility="yes">

                        <View
                            android:id="@+id/dexcomStatusDot"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_status_dot_disconnected"
                            android:importantForAccessibility="no" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="-0.02"
                            android:text="@string/home_dexcom_card_title"
                            android:textColor="@color/wg7_text_primary"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/dexcomCardStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:lineSpacingMultiplier="1.2"
                            android:textColor="@color/wg7_text_secondary"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/dexcomDisconnectLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_home_text_button"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingStart="10dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="6dp"
                        android:text="@string/home_dexcom_disconnect"
                        android:textColor="@color/wg7_alert"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <ImageView
                        android:id="@+id/dexcomCardChevron"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_forward_24"
                        app:tint="@color/wg7_text_tertiary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/homeSectionPilotLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/wg7_screen_pad_h"
                android:layout_marginTop="28dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="-0.01"
                android:text="@string/home_section_pilotage"
                android:textColor="@color/wg7_text_tertiary"
                android:textSize="13sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/dexcomCard" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/installCard"
                style="@style/Widget.WidgetG7.SectionCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/wg7_screen_pad_h"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="@dimen/wg7_screen_pad_h"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/homeSectionPilotLabel">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/wg7_watch_card_pad"
                    android:paddingTop="@dimen/wg7_watch_card_pad"
                    android:paddingEnd="@dimen/wg7_watch_card_pad"
                    android:paddingBottom="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:baselineAligned="false"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:id="@+id/watchVisualFrame"
                            android:layout_width="@dimen/wg7_watch_card_image_size"
                            android:layout_height="@dimen/wg7_watch_card_image_size"
                            android:background="@drawable/bg_home_icon_tonal"
                            android:contentDescription="@string/home_watch_status_unlinked_desc"
                            android:importantForAccessibility="yes">

                            <ImageView
                                android:id="@+id/watchCardImage"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@null"
                                android:importantForAccessibility="no"
                                android:padding="6dp"
                                android:scaleType="fitCenter"
                                android:src="@drawable/illustration_round_watch_generic" />

                            <View
                                android:id="@+id/watchStatusDot"
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:layout_gravity="bottom|end"
                                android:layout_margin="6dp"
                                android:background="@drawable/bg_status_dot_disconnected"
                                android:importantForAccessibility="no" />
                        </FrameLayout>

                        <LinearLayout
                            android:id="@+id/watchCardBody"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:minHeight="@dimen/wg7_watch_card_image_size"
                            android:gravity="center_vertical"
                            android:orientation="vertical"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-medium"
                                android:letterSpacing="-0.02"
                                android:text="@string/home_watch_card_title"
                                android:textColor="@color/wg7_text_primary"
                                android:textSize="19sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/watchCardStatus"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:ellipsize="end"
                                android:maxLines="2"
                                android:text="@string/home_watch_status_off"
                                android:textColor="@color/wg7_text_secondary"
                                android:textSize="15sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/watchTestButton"
                        style="@style/Widget.WidgetG7.SecondaryButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:minHeight="48dp"
                        android:text="@string/home_watch_test" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <TextView
        android:id="@+id/openNoticeButton"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:layout_gravity="bottom|end"
        android:alpha="0"
        android:text="Notice" />
</FrameLayout>
