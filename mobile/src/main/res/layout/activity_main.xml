<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Widget G7"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Suivi glucose simple sur telephone et montre"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/glucoseValueText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="--"
            android:textSize="56sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/glucoseTrendText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Derniere tendance indisponible"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/lastSyncText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Derniere sync: aucune pour le moment"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/syncStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Etat: en attente d'une premiere synchronisation"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/dexcomStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Dexcom: a configurer"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/watchStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Aucune montre detectee"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/batteryStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Batterie: etat inconnu"
            android:textSize="15sp" />

        <Button
            android:id="@+id/refreshNowButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Actualiser maintenant" />

        <Button
            android:id="@+id/improveSyncButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Ameliorer la synchronisation" />

        <Button
            android:id="@+id/configureDexcomButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Configurer Dexcom" />

        <Button
            android:id="@+id/configureWatchButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Configurer la montre" />

    </LinearLayout>
</ScrollView>
