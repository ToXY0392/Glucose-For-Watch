<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:clipToPadding="false"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingTop="28dp"
        android:paddingEnd="28dp"
        android:paddingBottom="36dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="900dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="700dp"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="8dp">

                <View
                    android:layout_width="560dp"
                    android:layout_height="560dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_watch_hero_glow"
                    android:alpha="0.9" />

                <ImageView
                    android:id="@+id/watchPreviewImage"
                    android:layout_width="680dp"
                    android:layout_height="680dp"
                    android:layout_gravity="center"
                    android:adjustViewBounds="true"
                    android:contentDescription="Montre connectée"
                    android:scaleType="fitCenter"
                    android:src="@drawable/watch_photo_transparent" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="138dp"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingBottom="0dp">

                <ImageButton
                    android:id="@+id/watchSettingsButton"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_round_icon_button"
                    android:contentDescription="Paramètres"
                    android:padding="10dp"
                    android:src="@drawable/ic_settings_24"
                    android:tint="@color/text_primary" />

                <TextView
                    android:id="@+id/watchFaceStatusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Connectée"
                    android:textColor="@color/state_success"
                    android:textSize="44sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/watchModelText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="0dp"
                    android:text="Google Pixel Watch 2"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/watchRefreshButton"
                    style="@style/Widget.WidgetG7.Button.Link"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="-2dp"
                    android:minWidth="0dp"
                    android:text="Actualiser" />
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/dexcomCardHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_card_surface"
            android:gravity="center_vertical"
            android:minHeight="104dp"
            android:orientation="horizontal"
            android:paddingStart="34dp"
            android:paddingTop="22dp"
            android:paddingEnd="34dp"
            android:paddingBottom="22dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="DEXCOM"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/dexcomStatusDot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:text="●"
                android:textColor="@color/state_success"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/dexcomCardSummaryText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connecté"
                android:textColor="@color/state_success"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/dexcomCardContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_card_surface"
            android:orientation="vertical"
            android:paddingStart="30dp"
            android:paddingTop="28dp"
            android:paddingEnd="30dp"
            android:paddingBottom="28dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Utilisez vos identifiants Dexcom pour gérer la connexion de l'application."
                android:textColor="@color/text_secondary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/configureDexcomButton"
                style="@style/Widget.WidgetG7.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Ouvrir Dexcom" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/permissionsCardHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_card_surface"
            android:gravity="center_vertical"
            android:minHeight="104dp"
            android:orientation="horizontal"
            android:paddingStart="34dp"
            android:paddingTop="22dp"
            android:paddingEnd="34dp"
            android:paddingBottom="22dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="AUTORISATIONS"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/permissionsCardContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_card_surface"
            android:orientation="vertical"
            android:paddingStart="30dp"
            android:paddingTop="28dp"
            android:paddingEnd="30dp"
            android:paddingBottom="28dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/notificationsHelpText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Notifications"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/notificationsStepsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Paramètres du téléphone > Applications > Widget G7 Phone > Notifications > Autoriser les notifications."
                android:textColor="@color/text_secondary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/openNotificationsSettingsButton"
                style="@style/Widget.WidgetG7.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Ouvrir les notifications" />

            <TextView
                android:id="@+id/batteryHelpText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Batterie"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/batteryStepsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Paramètres du téléphone > Applications > Widget G7 Phone > Utilisation de la batterie par l'application > Autoriser l'utilisation en arrière-plan."
                android:textColor="@color/text_secondary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/openAppSettingsButton"
                style="@style/Widget.WidgetG7.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Ouvrir les infos de l'application" />
        </LinearLayout>

        <Button
            android:id="@+id/openNoticeButton"
            style="@style/Widget.WidgetG7.Button.Link"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            android:minWidth="0dp"
            android:text="Voir la notice" />
    </LinearLayout>
</ScrollView>
