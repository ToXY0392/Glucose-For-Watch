<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_companion_canvas">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:scrollbars="none">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="32dp">

            <TextView
                android:id="@+id/homeHeaderTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/wg7_screen_pad_h"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="8dp"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:text="@string/app_name"
                android:textColor="@color/wg7_text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/syncNowButton"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageButton
                android:id="@+id/syncNowButton"
                android:layout_width="@dimen/wg7_touch_min"
                android:layout_height="@dimen/wg7_touch_min"
                android:layout_marginEnd="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/home_sync_content_description"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_refresh_24"
                app:layout_constraintBottom_toBottomOf="@id/homeHeaderTitle"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/homeHeaderTitle"
                app:tint="@color/wg7_icon_tint" />

            <FrameLayout
                android:id="@+id/watchFacePreview"
                android:layout_width="@dimen/wg7_companion_watch_size"
                android:layout_height="@dimen/wg7_companion_watch_size"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_watch_face_preview"
                android:importantForAccessibility="no"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/homeHeaderTitle">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp">

                    <TextView
                        android:id="@+id/homeWatchFaceValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:includeFontPadding="false"
                        android:letterSpacing="-0.04"
                        android:text="@string/home_companion_watch_face_empty"
                        android:textColor="@color/wg7_text_tertiary"
                        android:textSize="56sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/homeWatchFaceMeta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:letterSpacing="0.02"
                        android:textColor="@color/wg7_watch_face_meta"
                        android:textSize="14sp" />
                </LinearLayout>
            </FrameLayout>

            <LinearLayout
                android:id="@+id/homeCompanionStatusRow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/wg7_screen_pad_h"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="@dimen/wg7_screen_pad_h"
                android:gravity="center"
                android:importantForAccessibility="no"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/watchFacePreview">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_bluetooth_24"
                    app:tint="@color/wg7_icon_tint" />

                <TextView
                    android:id="@+id/homeConnectionStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textColor="@color/wg7_text_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:text="┬À"
                    android:textColor="@color/wg7_text_tertiary"
                    android:textSize="14sp" />

                <ImageView
                    android:id="@+id/homeBatteryIcon"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_battery_24"
                    app:tint="@color/wg7_icon_tint" />

                <TextView
                    android:id="@+id/homeBatteryStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textColor="@color/wg7_text_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/homeStatusSeparator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:text="┬À"
                    android:textColor="@color/wg7_text_tertiary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/homeSyncAgeStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/wg7_text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/homeSyncStatusLine"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="14dp"
                android:paddingTop="6dp"
                android:paddingEnd="14dp"
                android:paddingBottom="6dp"
                android:textSize="13sp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/homeCompanionStatusRow" />

            <TextView
                android:id="@+id/homeSettingsHeading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/wg7_screen_pad_h"
                android:layout_marginTop="28dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/home_companion_section_settings"
                android:textColor="@color/wg7_companion_section"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/homeSyncStatusLine" />

            <LinearLayout
                android:id="@+id/homeSettingsGroup"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/wg7_screen_pad_h"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="@dimen/wg7_screen_pad_h"
                android:background="@drawable/bg_companion_settings_group"
                android:orientation="vertical"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/homeSettingsHeading">

                <LinearLayout
                    android:id="@+id/homeBatterySettingRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_companion_settings_row"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="@dimen/wg7_row_min_height"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="14dp">

                    <ImageView
                        android:layout_width="@dimen/wg7_companion_settings_icon"
                        android:layout_height="@dimen/wg7_companion_settings_icon"
                        android:background="@drawable/bg_home_icon_tonal"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        android:padding="8dp"
                        android:src="@drawable/ic_battery_saver_24"
                        app:tint="@color/wg7_icon_tint" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/home_companion_setting_battery_title"
                            android:textColor="@color/wg7_text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/homeBatterySettingSubtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="@color/wg7_text_secondary"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_chevron_forward_24"
                        app:tint="@color/wg7_icon_tint" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/dexcomRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_companion_settings_row"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="@dimen/wg7_row_min_height"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="14dp">

                    <ImageView
                        android:layout_width="@dimen/wg7_companion_settings_icon"
                        android:layout_height="@dimen/wg7_companion_settings_icon"
                        android:background="@drawable/bg_home_icon_tonal"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        android:padding="8dp"
                        android:src="@drawable/ic_sensor_glucose"
                        app:tint="@color/wg7_icon_tint" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/home_companion_setting_dexcom_title"
                            android:textColor="@color/wg7_text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/dexcomRowStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="@color/wg7_text_secondary"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_chevron_forward_24"
                        app:tint="@color/wg7_icon_tint" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/watchRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_companion_settings_row"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="@dimen/wg7_row_min_height"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="14dp">

                    <ImageView
                        android:layout_width="@dimen/wg7_companion_settings_icon"
                        android:layout_height="@dimen/wg7_companion_settings_icon"
                        android:background="@drawable/bg_home_icon_tonal"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        android:padding="8dp"
                        android:src="@drawable/ic_watch_24"
                        app:tint="@color/wg7_icon_tint" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/home_companion_setting_watch_title"
                            android:textColor="@color/wg7_text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/watchRowStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:ellipsize="end"
                            android:maxLines="2"
                            android:text="@string/home_watch_status_off"
                            android:textColor="@color/wg7_text_secondary"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_chevron_forward_24"
                        app:tint="@color/wg7_icon_tint" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/homeInstallSettingRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_companion_settings_row"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="@dimen/wg7_row_min_height"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="14dp">

                    <ImageView
                        android:layout_width="@dimen/wg7_companion_settings_icon"
                        android:layout_height="@dimen/wg7_companion_settings_icon"
                        android:background="@drawable/bg_home_icon_tonal"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        android:padding="8dp"
                        android:src="@drawable/ic_watch_install"
                        app:tint="@color/wg7_icon_tint" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/home_companion_setting_install_title"
                            android:textColor="@color/wg7_text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/home_companion_setting_install_sub"
                            android:textColor="@color/wg7_text_secondary"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_chevron_forward_24"
                        app:tint="@color/wg7_icon_tint" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/openNoticeButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_companion_settings_row"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="@dimen/wg7_row_min_height"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="14dp">

                    <ImageView
                        android:layout_width="@dimen/wg7_companion_settings_icon"
                        android:layout_height="@dimen/wg7_companion_settings_icon"
                        android:background="@drawable/bg_home_icon_tonal"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        android:padding="8dp"
                        android:src="@drawable/ic_share_24"
                        app:tint="@color/wg7_icon_tint" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/home_companion_setting_notice_title"
                            android:textColor="@color/wg7_text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/home_companion_setting_notice_sub"
                            android:textColor="@color/wg7_text_secondary"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_chevron_forward_24"
                        app:tint="@color/wg7_icon_tint" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/homePermissionsRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_companion_settings_row"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="@dimen/wg7_row_min_height"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="14dp">

                    <ImageView
                        android:layout_width="@dimen/wg7_companion_settings_icon"
                        android:layout_height="@dimen/wg7_companion_settings_icon"
                        android:background="@drawable/bg_home_icon_tonal"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        android:padding="8dp"
                        android:src="@drawable/ic_lock_24"
                        app:tint="@color/wg7_icon_tint" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/home_companion_setting_permissions_title"
                            android:textColor="@color/wg7_text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/home_companion_setting_permissions_sub"
                            android:textColor="@color/wg7_text_secondary"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_chevron_forward_24"
                        app:tint="@color/wg7_icon_tint" />
                </LinearLayout>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</FrameLayout>
