<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_mobile_backdrop">

    <ScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="32dp"
            android:paddingTop="70dp"
            android:paddingEnd="32dp"
            android:paddingBottom="36dp">

            <ImageView
                android:id="@+id/appLogoImage"
                android:layout_width="170dp"
                android:layout_height="118dp"
                android:adjustViewBounds="true"
                android:contentDescription="Widget G7"
                android:scaleType="fitCenter"
                android:src="@drawable/logo_widget_g7_official" />

            <TextView
                android:id="@+id/homeHeadlineText"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:alpha="0"
                android:text="Widget G7"
                android:textColor="@color/wg7_accent_dark"
                android:textSize="1sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/installCard"
                    android:layout_width="match_parent"
                    android:layout_height="104dp"
                    android:background="@drawable/bg_install_step_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="24dp"
                    android:paddingEnd="22dp">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_watch_install" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="24dp"
                        android:layout_weight="1"
                        android:text="Installer Wear"
                        android:textColor="@color/wg7_text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/installCheckIcon"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_check_24" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/syncCard"
                    android:layout_width="match_parent"
                    android:layout_height="104dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_install_step_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="24dp"
                    android:paddingEnd="22dp">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_refresh_24"
                        android:tint="@color/wg7_accent_dark" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="24dp"
                        android:layout_weight="1"
                        android:text="Sync"
                        android:textColor="@color/wg7_text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/syncCheckIcon"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_check_24" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ackCard"
                    android:layout_width="match_parent"
                    android:layout_height="104dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_install_step_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="24dp"
                    android:paddingEnd="22dp">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_watch_ack" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="24dp"
                        android:layout_weight="1"
                        android:text="Ack montre"
                        android:textColor="@color/wg7_text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/ackCheckIcon"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_check_24" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <ImageButton
        android:id="@+id/watchSettingsButton"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="18dp"
        android:alpha="0.01"
        android:background="@android:color/transparent"
        android:contentDescription="Parametres"
        android:padding="10dp"
        android:src="@drawable/ic_settings_24" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/watchRefreshButton"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:alpha="0"
        android:enabled="true"
        android:text="Synchroniser" />

    <TextView
        android:id="@+id/openNoticeButton"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:alpha="0"
        android:text="Notice" />

    <TextView
        android:id="@+id/homeSupportText"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:alpha="0" />

    <TextView
        android:id="@+id/installCardStatus"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:alpha="0" />

    <TextView
        android:id="@+id/syncCardStatus"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:alpha="0" />

    <TextView
        android:id="@+id/ackCardStatus"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:alpha="0" />

    <LinearLayout
        android:id="@+id/watchActionRow"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:alpha="0"
        android:orientation="horizontal" />
</FrameLayout>
