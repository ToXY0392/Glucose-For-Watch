<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_premium_canvas">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:scrollbars="none">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="40dp">

            <ImageButton
                android:id="@+id/watchSettingsButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/menu_content_description"
                android:padding="12dp"
                android:src="@drawable/ic_settings_24"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/wg7_text_tertiary" />

            <ImageView
                android:id="@+id/appLogoImage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="36dp"
                android:adjustViewBounds="true"
                android:contentDescription="@string/app_name"
                android:maxWidth="280dp"
                android:maxHeight="280dp"
                android:scaleType="fitCenter"
                android:src="@drawable/logo_widget_g7_official"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/heroCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/wg7_screen_pad_h"
                android:layout_marginTop="32dp"
                android:layout_marginEnd="@dimen/wg7_screen_pad_h"
                app:cardBackgroundColor="@color/wg7_surface"
                app:cardCornerRadius="@dimen/wg7_card_radius_hero"
                app:cardElevation="3dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/appLogoImage"
                app:strokeColor="@color/wg7_outline"
                app:strokeWidth="@dimen/wg7_card_stroke">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="26dp"
                    android:paddingTop="24dp"
                    android:paddingEnd="26dp"
                    android:paddingBottom="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/homeReadingPrimary"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="-0.02"
                            android:lineSpacingExtra="2dp"
                            android:textColor="@color/wg7_text_primary"
                            android:textSize="46sp"
                            android:textStyle="bold" />

                        <ImageButton
                            android:id="@+id/syncNowButton"
                            android:layout_width="@dimen/wg7_touch_min"
                            android:layout_height="@dimen/wg7_touch_min"
                            android:layout_marginStart="8dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="@string/home_sync_content_description"
                            android:padding="12dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_refresh_24"
                            app:tint="@color/wg7_accent_dark" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/homeReadingSubtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:lineSpacingMultiplier="1.28"
                        android:textColor="@color/wg7_text_secondary"
                        android:textSize="17sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="22dp"
                        android:background="@color/wg7_outline" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:letterSpacing="0.04"
                        android:text="@string/home_status_heading"
                        android:textAllCaps="true"
                        android:textColor="@color/wg7_text_tertiary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/homeStatusText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:lineSpacingMultiplier="1.22"
                        android:textColor="@color/wg7_accent_dark"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/dexcomCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/wg7_screen_pad_h"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="@dimen/wg7_screen_pad_h"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/wg7_surface"
                app:cardCornerRadius="@dimen/wg7_card_radius_list"
                app:cardElevation="2dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/heroCard"
                app:strokeColor="@color/wg7_outline"
                app:strokeWidth="@dimen/wg7_card_stroke">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:minHeight="80dp"
                    android:orientation="horizontal"
                    android:paddingStart="20dp"
                    android:paddingTop="18dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="18dp">

                    <FrameLayout
                        android:layout_width="@dimen/wg7_icon_tonal_size"
                        android:layout_height="@dimen/wg7_icon_tonal_size"
                        android:background="@drawable/bg_home_icon_tonal">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@null"
                            android:padding="@dimen/wg7_icon_tonal_padding"
                            android:scaleType="fitCenter"
                            android:src="@drawable/logo_widget_g7_official" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/home_dexcom_card_title"
                            android:textColor="@color/wg7_text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/dexcomCardStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:lineSpacingMultiplier="1.2"
                            android:textColor="@color/wg7_text_secondary"
                            android:textSize="15sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/dexcomDisconnectLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingStart="10dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="8dp"
                        android:text="@string/home_dexcom_disconnect"
                        android:textColor="@color/wg7_accent_dark"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <ImageView
                        android:id="@+id/dexcomCardChevron"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_forward_24"
                        app:tint="@color/wg7_text_secondary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/installCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/wg7_screen_pad_h"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="@dimen/wg7_screen_pad_h"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/wg7_surface"
                app:cardCornerRadius="@dimen/wg7_card_radius_list"
                app:cardElevation="2dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/dexcomCard"
                app:strokeColor="@color/wg7_outline"
                app:strokeWidth="@dimen/wg7_card_stroke">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:minHeight="92dp"
                    android:orientation="horizontal"
                    android:paddingStart="20dp"
                    android:paddingTop="18dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="18dp">

                    <FrameLayout
                        android:layout_width="@dimen/wg7_icon_tonal_size"
                        android:layout_height="@dimen/wg7_icon_tonal_size"
                        android:background="@drawable/bg_home_icon_tonal">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@null"
                            android:padding="@dimen/wg7_icon_tonal_padding"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_watch_install" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/home_watch_card_title"
                            android:textColor="@color/wg7_text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:lineSpacingMultiplier="1.2"
                            android:text="@string/home_watch_card_subtitle"
                            android:textColor="@color/wg7_text_secondary"
                            android:textSize="15sp" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/installChevron"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_forward_24"
                        app:tint="@color/wg7_text_secondary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/wearAssistantCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/wg7_screen_pad_h"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="@dimen/wg7_screen_pad_h"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/wg7_surface"
                app:cardCornerRadius="@dimen/wg7_card_radius_list"
                app:cardElevation="2dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/installCard"
                app:strokeColor="@color/wg7_outline"
                app:strokeWidth="@dimen/wg7_card_stroke">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:minHeight="80dp"
                    android:orientation="horizontal"
                    android:paddingStart="20dp"
                    android:paddingTop="18dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="18dp">

                    <FrameLayout
                        android:layout_width="@dimen/wg7_icon_tonal_size"
                        android:layout_height="@dimen/wg7_icon_tonal_size"
                        android:background="@drawable/bg_home_icon_tonal">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@null"
                            android:padding="@dimen/wg7_icon_tonal_padding"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_share_24"
                            app:tint="@color/wg7_accent_dark" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/wear_setup_install_assistant"
                            android:textColor="@color/wg7_text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:lineSpacingMultiplier="1.2"
                            android:text="@string/home_wear_assistant_subtitle"
                            android:textColor="@color/wg7_text_secondary"
                            android:textSize="15sp" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/wearAssistantChevron"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_forward_24"
                        app:tint="@color/wg7_text_secondary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <TextView
        android:id="@+id/openNoticeButton"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:layout_gravity="bottom|end"
        android:alpha="0"
        android:text="Notice" />

    <LinearLayout
        android:id="@+id/watchActionRow"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:layout_gravity="bottom|end"
        android:alpha="0"
        android:orientation="horizontal" />
</FrameLayout>
