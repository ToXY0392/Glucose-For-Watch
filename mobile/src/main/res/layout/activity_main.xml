<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_mobile_backdrop"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="24dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Widget G7"
            android:textColor="@color/wg7_accent_dark"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Une app compagnon pour installer le tile, relier la montre et garder la sync fiable."
            android:textColor="@color/wg7_text_secondary"
            android:textSize="15sp" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.WidgetG7.SectionCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <TextView
                    android:id="@+id/appStatusHeadlineText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Configuration requise"
                    android:textColor="@color/wg7_text_primary"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/appStatusDetailText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Commencez par configurer Dexcom puis vérifiez la montre."
                    android:textColor="@color/wg7_text_secondary"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/lastSyncText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Dernière sync : aucune pour le moment"
                    android:textColor="@color/wg7_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/dexcomStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Dexcom : à configurer"
                    android:textColor="@color/wg7_text_primary"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/watchStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Aucune montre détectée"
                    android:textColor="@color/wg7_text_primary"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/syncStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="État : en attente d'une première synchronisation"
                    android:textColor="@color/wg7_text_secondary"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/batteryStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Batterie : état inconnu"
                    android:textColor="@color/wg7_text_secondary"
                    android:textSize="15sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.WidgetG7.SectionCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <TextView
                    android:id="@+id/setupHintText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Configurez Dexcom, ouvrez la configuration montre, puis installez le tile ou le widget."
                    android:textColor="@color/wg7_text_secondary"
                    android:textSize="15sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/configureDexcomButton"
                    style="@style/Widget.WidgetG7.PrimaryButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Configurer Dexcom" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/configureWatchButton"
                    style="@style/Widget.WidgetG7.SecondaryButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Configurer la montre" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/refreshNowButton"
                style="@style/Widget.WidgetG7.PrimaryButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Vérifier la synchronisation" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/improveSyncButton"
                style="@style/Widget.WidgetG7.SecondaryButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Retirer la restriction batterie" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
