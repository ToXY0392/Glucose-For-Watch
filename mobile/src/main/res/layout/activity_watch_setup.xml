<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/watchSetupScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_mobile_backdrop"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="12dp"
        android:paddingEnd="20dp"
        android:paddingBottom="14dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Configuration de la montre"
            android:textColor="@color/wg7_text_primary"
            android:textSize="29sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="2dp"
            android:text="Vérifiez la liaison avec la montre et retrouvez en un instant les étapes utiles pour afficher la glycémie."
            android:textColor="@color/wg7_text_secondary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.WidgetG7.SectionCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="22dp"
                android:paddingTop="18dp"
                android:paddingEnd="22dp"
                android:paddingBottom="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="État de connexion"
                    android:textColor="@color/wg7_text_primary"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/watchStatusHeadlineText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Montre connectée : Google Pixel Watch 2"
                    android:textColor="@color/wg7_text_secondary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/watchStatusSupportText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Liaison détectée"
                    android:textColor="@color/wg7_text_secondary"
                    android:textSize="14sp" />

                <FrameLayout
                    android:id="@+id/watchHeroFrame"
                    android:layout_width="match_parent"
                    android:layout_height="190dp"
                    android:layout_marginTop="6dp">

                    <ImageView
                        android:id="@+id/watchHeroImage"
                        android:layout_width="170dp"
                        android:layout_height="170dp"
                        android:layout_gravity="center"
                        android:adjustViewBounds="true"
                        android:contentDescription="Montre connectée"
                        android:scaleType="fitCenter"
                        android:src="@drawable/illustration_pixel_watch_2" />
                </FrameLayout>

                <TextView
                    android:id="@+id/watchSetupStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:lineSpacingExtra="2dp"
                    android:text="Vérification de la liaison montre..."
                    android:textColor="@color/wg7_text_secondary"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/watchSelectorLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Montre principale"
                    android:textColor="@color/wg7_text_secondary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <Spinner
                    android:id="@+id/watchSelectorSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@color/wg7_surface_alt"
                    android:paddingStart="12dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="8dp"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/refreshWatchStatusButton"
                    style="@style/Widget.WidgetG7.PrimaryButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Vérifier la connexion montre" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.WidgetG7.SectionCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="22dp"
                android:paddingTop="18dp"
                android:paddingEnd="22dp"
                android:paddingBottom="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mise en route rapide"
                    android:textColor="@color/wg7_text_primary"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="1. Vérifiez que la montre est bien connectée au téléphone."
                    android:textColor="@color/wg7_text_secondary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="2. Ajoutez le tile Glucose Tile depuis le carrousel de tiles."
                    android:textColor="@color/wg7_text_secondary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="3. Pour le cadran, ajoutez la complication Glucose sur un emplacement texte."
                    android:textColor="@color/wg7_text_secondary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="4. Revenez à l'accueil puis utilisez Actualiser maintenant si besoin."
                    android:textColor="@color/wg7_text_secondary"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <ImageButton
            android:id="@+id/backToHomeButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_round_icon_button"
            android:contentDescription="Retour"
            android:padding="10dp"
            android:src="@drawable/ic_back_arrow"
            android:tint="@color/text_primary" />

    </LinearLayout>
</ScrollView>
