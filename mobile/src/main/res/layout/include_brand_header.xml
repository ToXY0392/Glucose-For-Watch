<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:contentDescription="@string/app_name"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <FrameLayout
        android:layout_width="@dimen/wg7_icon_tonal_size"
        android:layout_height="@dimen/wg7_icon_tonal_size"
        android:background="@drawable/bg_home_icon_tonal">

        <ImageView
            android:layout_width="@dimen/wg7_icon_square_inner"
            android:layout_height="@dimen/wg7_icon_square_inner"
            android:layout_gravity="center"
            android:contentDescription="@null"
            android:importantForAccessibility="no"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_brand_wg7_mark" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:importantForAccessibility="no"
            android:fontFamily="sans-serif-medium"
            android:includeFontPadding="false"
            android:letterSpacing="-0.045"
            android:text="@string/app_name"
            android:textColor="@color/wg7_text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:importantForAccessibility="no"
            android:includeFontPadding="false"
            android:letterSpacing="0.1"
            android:text="@string/home_brand_tagline"
            android:textAllCaps="true"
            android:textColor="@color/wg7_accent"
            android:textSize="9sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
