<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connexion Dexcom"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Entrez votre compte Dexcom Share pour synchroniser automatiquement votre glycemie vers la montre."
            android:textSize="15sp" />

        <TextView
            android:id="@+id/dexcomAccountSummaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Compte Dexcom non configure"
            android:textSize="15sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/dexcomUsernameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:hint="Email ou identifiant Dexcom"
            android:inputType="textEmailAddress" />

        <EditText
            android:id="@+id/dexcomPasswordInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Mot de passe"
            android:inputType="textPassword" />

        <AutoCompleteTextView
            android:id="@+id/dexcomServerInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Region"
            android:inputType="none" />

        <Button
            android:id="@+id/testDexcomButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Tester la connexion" />

        <Button
            android:id="@+id/saveDexcomButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Enregistrer" />

        <Button
            android:id="@+id/disconnectDexcomButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Deconnecter le compte" />

        <TextView
            android:id="@+id/dexcomSettingsStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Aucune verification effectuee pour le moment."
            android:textSize="15sp" />

    </LinearLayout>
</ScrollView>
