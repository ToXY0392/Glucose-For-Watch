<resources>
    <!-- Generated from toxy-ux-kit/tokens/ — AGP medical layer — glucose range colors only -->
    <!-- Run: python toxy-ux-kit/tools/export-android-colors.py -->

    <!-- Level 2 hypoglycemia — < 54 mg/dL -->
    <color name="agp_veryLow">#9C0000</color>
    <!-- Level 1 hypoglycemia — 54–69 mg/dL -->
    <color name="agp_low">#E00000</color>
    <!-- Time in Range — 70–180 mg/dL -->
    <color name="agp_inRange">#008000</color>
    <!-- Level 1 hyperglycemia — 181–250 mg/dL -->
    <color name="agp_high">#FFCC00</color>
    <!-- Level 2 hyperglycemia — > 250 mg/dL -->
    <color name="agp_veryHigh">#FF9900</color>
    <!-- Stale, no data, or non-clinical muted trend — NOT a range -->
    <color name="agp_unknown">#64748B</color>
</resources>
